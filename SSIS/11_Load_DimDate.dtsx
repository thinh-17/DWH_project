      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{92C61F5A-46B9-4BA0-9D3F-5F0222D9D592}"
          SQLTask:SqlStatementSource="DECLARE @start DATE = '2016-01-01';&#xA;DECLARE @end DATE = '2020-12-31';&#xA;&#xA;WHILE @start &lt;= @end&#xA;BEGIN&#xA;    INSERT INTO dbo.DimDate&#xA;    (&#xA;        date_key,&#xA;        full_date,&#xA;        day_of_month,&#xA;        month_num,&#xA;        month_name,&#xA;        quarter_num,&#xA;        year_num&#xA;    )&#xA;    VALUES&#xA;    (&#xA;        CONVERT(INT, FORMAT(@start, 'yyyyMMdd')),&#xA;        @start,&#xA;        DAY(@start),&#xA;        MONTH(@start),&#xA;        DATENAME(MONTH, @start),&#xA;        DATEPART(QUARTER, @start),&#xA;        YEAR(@start)&#xA;    );&#xA;&#xA;    SET @start = DATEADD(DAY, 1, @start);&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
